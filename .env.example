# Copy this file to .env and fill in your real values.
# These same variables must be set in the Vercel project settings.

# LLMOD AI gateway (used for both embeddings and the chat model)
LLMOD_AI_API_KEY=sk-your-llmod-key
LLMOD_AI_URL=https://api.llmod.ai/v1

# Pinecone vector database
PINECONE_API_KEY=pcsk_your-pinecone-key
PINECONE_INDEX=medium-rag-index
